{
  "_doc": "PUBLIC clean-room denylist. Generic secret/home-path/PII patterns + already-public product names ONLY. Personal names, internal codenames, personal handles and exact usernames live in a PRIVATE denylist merged at scan time via FIREWALL_DENYLIST_EXTRA (kept outside every public repo). Matching runs over canonicalized text — see firewall-scan.mjs. Bias: when in doubt, block.",
  "hardBlock": ["alpha school", "alpha.school", "alphaschool", "2 hour learning", "2hr learning", "2hour learning", "two hour learning", "1edtech", "oneroster"],
  "hardBlockRegex": [
    "/users/[a-z][a-z0-9._-]*/(library|documents|desktop|downloads|movies|music|pictures|public|applications)\\b",
    "\\b(?:2|two)\\s*hours?\\s*learning\\b",
    "\\b2\\s*hr\\s*learning\\b",
    "sk-ant-[a-z0-9_-]{20,}",
    "sk-[a-z0-9]{32,}",
    "gh[oprsu]_[a-z0-9]{30,}",
    "github_pat_[a-z0-9_]{30,}",
    "xai-[a-z0-9]{20,}",
    "aiza[0-9a-z_-]{30,}",
    "akia[a-z0-9]{16}\\b",
    "xox[baprs]-[a-z0-9-]{10,}",
    "-----begin [a-z0-9 ]*private key-----"
  ],
  "contextWords": ["alpha"],
  "contextAllow": ["alpha release", "alpha version", "alpha test", "alpha stage", "alpha channel", "alpha blend", "alpha numeric", "alphanumeric", "alphabet", "alphago", "alphafold", "alphageometry", "alpha geometry", "alpha beta", "alpha decay", "alpha particle", "alpha centauri", "alpha waves", "alpha wave", "strategy alpha", "jensen's alpha", "jensens alpha", "portfolio alpha", "market alpha", "generate alpha", "cronbach's alpha", "cronbachs alpha", "cronbach alpha", "alpha coefficient", "alpha reliability", "alpha level", "alpha value", "alpha parameter", "significance alpha", "alpha of", "alpha =", "alpha equals", "dialpha", "ralpha"],
  "publicSubstrate": ["naep", "staar", "oer", "common core", "ngss", "pisa", "timss"]
}
